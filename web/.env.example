# Todoist API Key — get from https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_KEY=your_todoist_api_key_here

# Google AI (Gemini) API Key — get for free at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# Your work hours (24h format, used by the Daily Planner)
WORK_START_HOUR=9
WORK_END_HOUR=18

# Your timezone (used for scheduling)
TIMEZONE=Asia/Qatar
