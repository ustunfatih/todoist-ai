# Todoist API Key — get from https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_KEY=your_todoist_api_key_here

# ─── AI Provider ──────────────────────────────────────────────────────────────
# The app tries providers in order: Gemini 2.0 Flash → Gemini 1.5 Flash → Groq
# Set AI_PROVIDER=groq to skip Gemini entirely and always use Groq.
AI_PROVIDER=

# Google AI (Gemini) API Key — free at https://aistudio.google.com/apikey
# Free tier: 1,500 req/day. Groq is used automatically when quota is exceeded.
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# Groq API Key — free at https://console.groq.com (very generous: ~14,400 req/day)
# Used automatically when Gemini is over quota, or set AI_PROVIDER=groq to always use it.
# Model: Llama 3.3 70B (comparable quality to Gemini 2.0 Flash)
GROQ_API_KEY=your_groq_api_key_here

# ─── Scheduling ───────────────────────────────────────────────────────────────
# Your work hours (24h format, used by the Daily Planner)
WORK_START_HOUR=7
WORK_END_HOUR=19

# Your timezone (used for scheduling)
TIMEZONE=Asia/Qatar
